{
  "name": "vscode-decisiondrift",
  "displayName": "DecisionDrift",
  "description": "Architecture governance powered by ADRs — enforce rules directly in your editor",
  "version": "0.1.0",
  "publisher": "decisiondrift",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Programming Languages", "Other"],
  "keywords": ["adr", "architecture", "governance", "lint", "decision-record"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "decisiondrift.analyzeFile",
        "title": "DecisionDrift: Analyze Current File"
      },
      {
        "command": "decisiondrift.analyzeWorkspace",
        "title": "DecisionDrift: Analyze Entire Workspace"
      },
      {
        "command": "decisiondrift.showHealth",
        "title": "DecisionDrift: Show Health Report"
      }
    ],
    "configuration": {
      "title": "DecisionDrift",
      "properties": {
        "decisiondrift.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the `decisiondrift` CLI. Leave empty to autodiscover from PATH."
        },
        "decisiondrift.adrDir": {
          "type": "string",
          "default": "",
          "description": "Path to the ADR directory. Leave empty to use default (<workspace>/docs/adr)."
        },
        "decisiondrift.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run enforcement automatically when a file is saved."
        },
        "decisiondrift.runOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run enforcement automatically when a file is opened."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "decisiondrift", "title": "DecisionDrift", "icon": "icon.svg" }
      ]
    },
    "views": {
      "decisiondrift": [
        { "id": "decisiondrift.results", "name": "Findings" },
        { "id": "decisiondrift.adrs", "name": "ADRs" }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write src/",
    "pretest": "npm run compile",
    "test": "node out/test/runTests.js",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.50.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "@vscode/test-electron": "^2.3.0"
  }
}
