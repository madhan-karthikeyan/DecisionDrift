+@doctor_bp.route("/schedule", methods=["GET"])
+@jwt_required()
+def doctor_schedule():
+    user = get_current_user()
+    if not user or user.role != "doctor":
+        return jsonify({"error": "Doctor access required"}), 403
+    doctor = Doctor.query.filter_by(uuid=user.id).first()
+    if not doctor:
+        return jsonify({"error": "Doctor profile not found"}), 404
+    slots = DoctorAvailability.query.filter_by(doctor_id=doctor.id).all()
+    result = [{"day": s.day, "start": str(s.start_time), "end": str(s.end_time)} for s in slots]
+    return jsonify(result), 200
